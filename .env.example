# LLM API 설정 (OpenAI SDK 형식을 따르는 모든 LLM API 지원)
# 권장 모델: 알리바바 바이롄 qwen-plus https://bailian.console.aliyun.com/
# 사용량이 클 수 있으므로 먼저 40라운드 미만으로 테스트해 보세요.
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 경량: 청크 추출·OASIS 런타임·프로필 생성 등 대량 호출
LLM_MODEL_NAME=gemini-3.1-flash-lite-preview
# 고급 추론: 보고서/ReportAgent·온톨로지·시뮬레이션 설정 생성
LLM_REASONING_MODEL_NAME=gemini-3.1-pro-preview

# ===== 그래프 저장소 (Neo4j) =====
# Docker 예: docker compose up -d neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neofish_local
# Neo4j 장기 기억 유지 정책(선택)
NEO4J_MEMORY_MAX_EPISODES=300
NEO4J_MEMORY_MAX_ITEMS=1200
NEO4J_MEMORY_RETENTION_DAYS=30
NEO4J_MEMORY_MIN_EFFECTIVE_SCORE=32

# ===== LLM 가속 설정 (선택) =====
# 가속 설정을 사용하지 않는다면 아래 항목은 env 파일에 넣지 마세요.
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
